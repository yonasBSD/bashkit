{"id":"disc-find-by-category","category":"discovery","description":"Discover tools by category and fetch weather forecast","discovery_mode":true,"prompt":"You need the 5-day weather forecast for New York. First use `discover --category weather` to find the relevant tools. Then use `help` to learn the exact parameter names before calling the forecast tool. Print the forecast summary including each day's conditions.","tools":[{"name":"get_stock_price","description":"Get current stock price for a ticker symbol","schema":{"type":"object","properties":{"ticker":{"type":"string"}}},"category":"finance","tags":["read","market"],"mock":{"param":"ticker","responses":{"AAPL":"{\"ticker\":\"AAPL\",\"price\":185.50,\"change\":-1.2}"},"default":"{\"error\":\"unknown ticker\"}"}},{"name":"convert_currency","description":"Convert between currencies","schema":{"type":"object","properties":{"from":{"type":"string"},"to":{"type":"string"},"amount":{"type":"number"}}},"category":"finance","tags":["read","conversion"],"mock":"{\"from\":\"USD\",\"to\":\"EUR\",\"amount\":100,\"result\":92.5}"},{"name":"get_weather","description":"Get current weather for a city","schema":{"type":"object","properties":{"place_name":{"type":"string"}}},"category":"weather","tags":["read","current"],"mock":{"param":"place_name","responses":{"New York":"{\"city\":\"New York\",\"temp_f\":42,\"condition\":\"Partly Cloudy\",\"humidity\":65}","London":"{\"city\":\"London\",\"temp_f\":38,\"condition\":\"Rainy\",\"humidity\":80}"},"default":"{\"error\":\"city not found\"}"}},{"name":"get_forecast","description":"Get 5-day weather forecast for a city","schema":{"type":"object","properties":{"place_name":{"type":"string"}}},"category":"weather","tags":["read","forecast"],"mock":{"param":"place_name","responses":{"New York":"{\"city\":\"New York\",\"forecast\":[{\"day\":\"Mon\",\"high\":45,\"low\":32,\"condition\":\"Sunny\"},{\"day\":\"Tue\",\"high\":48,\"low\":35,\"condition\":\"Cloudy\"},{\"day\":\"Wed\",\"high\":40