{"id":"disc-tag-filter","category":"discovery","description":"Find read-only tools and compose multi-step customer profile query","discovery_mode":true,"prompt":"Build a customer profile for customer C-100. First use `discover --tag read` to find read-only tools. Then use `help` to learn the exact parameter names before calling the customer and purchase-history tools. Get the customer details and purchase history. Print the customer name and total purchase amount.","tools":[{"name":"get_customer","description":"Fetch customer profile by ID","schema":{"type":"object","properties":{"account_ref":{"type":"string"}}},"category":"customers","tags":["read"],"mock":{"param":"account_ref","responses":{"C-100":"{\"customer_id\":\"C-100\",\"name\":\"Alice Johnson\",\"email\":\"alice@example.com\",\"tier\":\"premium\"}"},"default":"{\"error\":\"customer not found\"}"}},{"name":"update_customer","description":"Update customer profile fields","schema":{"type":"object","properties":{"account_ref":{"type":"string"},"email":{"type":"string"}}},"category":"customers","tags":["write"],"mock":"{\"status\":\"updated\"}"},{"name":"delete_customer","description":"Delete a customer account permanently","schema":{"type":"object","properties":{"account_ref":{"type":"string"}}},"category":"customers","tags":["write","dangerous"],"mock":"{\"status\":\"deleted\"}"},{"name":"get_purchases","description":"Get purchase history for a customer","schema":{"type":"object","properties":{"account_ref":{"type":"string"}}},"category":"purchases","tags":["read"],"mock":{"param":"account_ref","responses":{"C-100":"[{\"purchase_id\":\"P-1\",\"amount\":59.99,\"product\":\"Widget A\",\"date\":\"2026-01-15\"},{\"purchase_id\":\"P-2\",\"amount\":129.50,\"product\":\"Gadget B\",\"date\":\"2026-02-20\"},{\"purchase_id\":\"P-3\",\"amount\":34.00,\"product\":\"Cable C\",\"date\":\"2026-03-01\"}]"},"default":"[]"}},{"name":"create_purchase","description":"Record a new purchase","schema":{"type":"object","properties"