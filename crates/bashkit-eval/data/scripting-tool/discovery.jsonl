{"id":"disc-search-then-use","category":"discovery","description":"Search for inventory tool and check stock levels","discovery_mode":true,"prompt":"Check the current stock level for product SKU-200. First use `discover --search inventory` to find the inventory tool. Then use `help` to learn the exact parameter names before calling it. Print the product name, SKU, and stock quantity.","tools":[{"name":"create_order","description":"Place a new purchase order","schema":{"type":"object","properties":{"product_sku":{"type":"string"},"quantity":{"type":"integer"}}},"category":"orders","tags":["write"],"mock":"{\"order_id\":\"PO-500\",\"status\":\"placed\"}"},{"name":"cancel_order","description":"Cancel an existing order","schema":{"type":"object","properties":{"order_id":{"type":"string"}}},"category":"orders","tags":["write"],"mock":"{\"status\":\"cancelled\"}"},{"name":"get_order_status","description":"Check status of an order","schema":{"type":"object","properties":{"order_id":{"type":"string"}}},"category":"orders","tags":["read"],"mock":"{\"order_id\":\"PO-500\",\"status\":\"shipped\"}"},{"name":"check_inventory","description":"Check current inventory stock for a product SKU","schema":{"type":"object","properties":{"product_code":{"type":"string"}}},"category":"inventory","tags":["read","stock"],"mock":{"param":"product_code","responses":{"SKU-200":"{\"sku\":\"SKU-200\",\"name\":\"Widget Pro\",\"quantity\":142,\"warehouse\":\"WH-East\"}","SKU-100":"{\"sku\":\"SKU-100\",\"name\":\"Widget Basic\",\"quantity\":0,\"warehouse\":\"WH-East\"}"},"default":"{\"error\":\"unknown SKU\"}"}},{"name":"update_inventory","description":"Update inventory count for a product","schema":{"type":"object","properties":{"product_code":{"type":"string"},"quantity":{"type":"integer"}}},"category":"inventory","tags":["write","stock"],"mock":"{\"status\":\"updated\"}"},{"name":"list_warehouses","description":"List all warehouse locations","schema":{"type":"object","properties":{}},"category":"